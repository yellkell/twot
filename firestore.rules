rules_version = '2';

// TWOT park + leaderboard rules.
//
// The posture: everything is world-READABLE (leaderboards are the point),
// every WRITE needs anonymous auth, and profile writes are scoped to your
// own uid. Rules can't validate transactional seat semantics or stat
// plausibility — the accepted worst case is a player inflating their OWN
// row. App Check is the future hardening step before this gets big.
service cloud.firestore {
  match /databases/{db}/documents {

    // players/{uid} — callsign, accent, lifetime stats. Yours to write.
    match /players/{uid} {
      allow read: if true;
      allow create, update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.callsign is string
        && request.resource.data.callsign.size() <= 24
        && request.resource.data.stats is map;
      allow delete: if false;
    }

    // parks/{parkId} — the persistent park doc: seats, names, heartbeats.
    // Any authed player may write (seat claims, heartbeats, janitoring),
    // shape-checked; the park doc itself is never deleted.
    match /parks/{parkId} {
      allow read: if true;
      allow create, update: if request.auth != null
        && request.resource.data.seats is list
        && request.resource.data.seats.size() <= 6;
      allow delete: if false;

      // WebRTC signaling: per-pair offer/answer docs + trickle-ICE
      // candidates. Ephemeral, authed, cleaned up best-effort on leave.
      match /sig/{pair} {
        allow read, write: if request.auth != null;
        match /{cands}/{c} {
          allow read, write: if request.auth != null;
        }
      }
    }
  }
}
